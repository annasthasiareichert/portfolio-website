---
// Grund-Layout: HTML-Rahmen, Kopfdaten (<head>), Schriften und globales CSS.
// Jede Seite wird in dieses Gerüst gesteckt (über <slot />).

// Schriften selbst gehostet (Fontsource) statt von Google geladen — beim Seitenaufruf
// wird keine IP-Adresse mehr an Google übermittelt (siehe Datenschutzerklärung).
// · Archivo    = aufrechte Grotesk, Gewichte 400–900
// · Newsreader = ruhige Serifen-KURSIV (300–500) für Eigennamen & editoriale Zeilen
// (Times New Roman im Namens-Lockup ist eine Systemschrift und wird nicht geladen.)
import "@fontsource/archivo/400.css";
import "@fontsource/archivo/500.css";
import "@fontsource/archivo/600.css";
import "@fontsource/archivo/700.css";
import "@fontsource/archivo/800.css";
import "@fontsource/archivo/900.css";
import "@fontsource/newsreader/300-italic.css";
import "@fontsource/newsreader/400-italic.css";
import "@fontsource/newsreader/500-italic.css";
import "../styles/global.css";

interface Props {
  titel?: string;
  beschreibung?: string;
}

const {
  titel = "Annasthasia Reichert — Grafik- & UI-Design",
  beschreibung = "Portfolio von Annasthasia Reichert — Grafik- & UI-Designerin aus Köln.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={beschreibung} />
    <!-- Favicon (AR im Kreis, immer voller Kontrast):
         helles System = weißer Kreis + schwarzes AR · Dark Mode = schwarzer Kreis + weißes AR -->
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <title>{titel}</title>

    <!--
      Schriften werden selbst gehostet (Fontsource-Import im Frontmatter oben) und nicht
      mehr von Google Fonts geladen — dadurch wird keine IP-Adresse an Google übermittelt.
      · Times New Roman = kursiver Vorname im Namens-Lockup (Systemschrift, kein Laden nötig)
      · Archivo         = fette, kleingeschriebene Grotesk (Nachname, Überschriften, Titel)
      · Newsreader      = ruhige Serifen-Kursiv für Eigennamen & editoriale Zeilen
    -->
  </head>
  <body>
    <!--
      Work-in-Progress-Hinweis: klar sichtbarer Diagonal-Banner in der oberen linken
      Ecke. Signalisiert Besucher:innen, dass die Seite ein Zwischenstand ist – nicht
      das finale Ergebnis. Liegt im Grundgerüst → erscheint auf allen Seiten.
      Der Text „WORK IN PROGRESS“ bleibt in DE wie EN gleich.
      pointer-events:none, damit die Wortmarke darunter klickbar bleibt.
    -->
    <div
      class="wip-ecke"
      role="note"
      aria-label="Hinweis: Diese Website ist noch in Arbeit (Work in Progress) – ein Zwischenstand, nicht das finale Ergebnis."
    >
      <span class="wip-band" aria-hidden="true">
        <span class="wip-text" data-de="Work in Progress" data-en="Work in Progress"
          >Work in Progress</span
        >
      </span>
    </div>

    <slot />
  </body>
</html>

---
// Grund-Layout: HTML-Rahmen, Kopfdaten (<head>), Schriften und globales CSS.
// Jede Seite wird in dieses Gerüst gesteckt (über <slot />).
import "../styles/global.css";

interface Props {
  titel?: string;
  beschreibung?: string;
}

const {
  titel = "Annasthasia Reichert — Grafik- & UI-Design",
  beschreibung = "Portfolio von Annasthasia Reichert — Grafik- & UI-Designerin aus Köln.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={beschreibung} />
    <!-- Favicon (AR-Monogramm): dunkle Schrift auf hellem Tab, helle Schrift im Dark Mode -->
    <link rel="icon" type="image/png" href="/favicon-dark.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/favicon-light.png" media="(prefers-color-scheme: dark)" />
    <title>{titel}</title>

    <!--
      Schriften nach dem Vorbild des Lebenslaufs:
      · Times New Roman = kursiver Vorname im Namens-Lockup (Systemschrift, kein Laden nötig)
      · Archivo         = fette, kleingeschriebene Grotesk (Nachname, Überschriften, Titel)
      · Newsreader      = ruhige Serifen-Kursiv für Eigennamen & editoriale Zeilen
      Archivo & Newsreader sind lizenzfrei (Open Font License) und später selbst hostbar.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=Newsreader:ital,opsz,wght@1,6..72,300..500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!--
      Work-in-Progress-Hinweis: klar sichtbarer Diagonal-Banner in der oberen linken
      Ecke. Signalisiert Besucher:innen, dass die Seite ein Zwischenstand ist – nicht
      das finale Ergebnis. Liegt im Grundgerüst → erscheint auf allen Seiten.
      Der Text „WORK IN PROGRESS“ bleibt in DE wie EN gleich.
      pointer-events:none, damit die Wortmarke darunter klickbar bleibt.
    -->
    <div
      class="wip-ecke"
      role="note"
      aria-label="Hinweis: Diese Website ist noch in Arbeit (Work in Progress) – ein Zwischenstand, nicht das finale Ergebnis."
    >
      <span class="wip-band" aria-hidden="true">
        <span class="wip-text" data-de="Work in Progress" data-en="Work in Progress"
          >Work in Progress</span
        >
      </span>
    </div>

    <slot />
  </body>
</html>

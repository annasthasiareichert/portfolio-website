  { gruppe: "Kontakt & Fuß", k: "kontakt-daten", name: "Kontaktdaten", wo: "Kontaktseite (Adresse, Telefon)",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 500, style: "normal", size: "clamp(0.95rem, 1.4vw, 1.2rem)", tracking: "-0.005em", transform: "none", color: "var(--tinte)", bg: "var(--sand)", probe: "Lenbachstraße 9, 50733 Köln" },
  { gruppe: "Kontakt & Fuß", k: "footer-mail", name: "Fußzeilen-Mail", wo: "Startseiten-Fuß (Ton → Reinweiß bei Hover)",

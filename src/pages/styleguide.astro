    famVar: "var(--grotesk)", fam: "Archivo", weight: 800, style: "normal", size: "0.72rem", tracking: "0.16em", transform: "uppercase", color: "var(--papier)", bg: "var(--tinte)", probe: "Work in Progress" },

  // — Navigation & Interaktion —
  { gruppe: "Navigation & Interaktion", k: "nav", name: "Navigationslink", wo: "Kopfzeile (Hover/aktiv → 700; mobil 1.75rem/600)",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 500, style: "normal", size: "0.95rem", tracking: "0", transform: "none", color: "var(--tinte)", bg: "var(--papier)", probe: "Arbeiten" },
  { gruppe: "Navigation & Interaktion", k: "pille", name: "Outline-Pille", wo: "Badge im CV-Stil (.pill), Leistungen",

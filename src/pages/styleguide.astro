<script>
  // Live-Größen + Viewport-Badge. Liest die tatsächlich gerenderte font-size jeder
  // Probe (clamp aufgelöst) und schreibt sie neben die clamp-Formel. Aktualisiert
  // bei jedem Resize → Desktop- und Mobil-Werte werden direkt sichtbar.
  const proben = Array.from(document.querySelectorAll<HTMLElement>(".sg-probe"));
  const badge = document.getElementById("sg-badge");

  function px(el: HTMLElement) {
    const fs = getComputedStyle(el).fontSize;
    return Math.round(parseFloat(fs) * 10) / 10 + " px";
  }

  function aktualisiere() {
    const b = window.innerWidth;
    const modus = b <= 760 ? "Mobil" : "Desktop";
    if (badge) badge.textContent = `${modus} · ${b} px`;
    proben.forEach((el) => {
      const k = el.getAttribute("data-k");
      const ziel = document.querySelector<HTMLElement>(`.sg-live[data-live="${k}"]`);
      if (ziel) ziel.textContent = px(el);
    });
  }

  aktualisiere();
  let t: number | undefined;
  window.addEventListener("resize", () => {
    window.clearTimeout(t);
    t = window.setTimeout(aktualisiere, 80);
  });
  document.fonts?.ready.then(aktualisiere);
</script>

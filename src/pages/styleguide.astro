  { gruppe: "Display & Signature", k: "seitentitel", name: "Seiten-/Sektionstitel", wo: "Lebenslauf, Impressum, Datenschutz, Projekt-Detail",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 900, style: "normal", size: "clamp(2rem, 5vw, 3.1rem)", tracking: "-0.02em", transform: "none", color: "#1b1b1b", bg: "var(--sand)", probe: "lebenslauf" },
  { gruppe: "Display & Signature", k: "kontakt-riese", name: "Kontakt-Riesentitel", wo: "Kontaktseite",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 900, style: "normal", size: "clamp(2.6rem, 6.6vw, 4.6rem)", tracking: "-0.01em", transform: "uppercase", color: "#FFFFFF", bg: "var(--sand)", probe: "KONTAKT" },
  { gruppe: "Display & Signature", k: "faecher-wort", name: "Fächer-Titelwort (hinter Karten)", wo: "Startseite „Arbeiten“ (Opazität 14 %)",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 900, style: "normal", size: "clamp(2.4rem, 9vw, 8.2rem)", tracking: "-0.03em", transform: "lowercase", color: "var(--tinte)", bg: "var(--papier)", probe: "ticket ag", opacity: 0.14 },
  { gruppe: "Display & Signature", k: "drift", name: "Wasserzeichen „design.“", wo: "Zwischenspiel-Parallax (Opazität 5 %)",

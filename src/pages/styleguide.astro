---
// STYLEGUIDE — interne Design-Übersicht (nicht in der Navigation verlinkt).
// Ganzheitliche Referenz aller Schriften, Schriftschnitte, Größen und Farben,
// gerendert mit den ECHTEN Projekt-Schriften (Archivo, Newsreader, Times) und
// den ECHTEN Farb-Tokens aus global.css. Die Größen wachsen per clamp() mit dem
// Viewport → beim Umschalten Desktop ↔ Mobil rechnet die Live-Anzeige neu.
// Diese Seite ist ein Arbeitswerkzeug; sie kann jederzeit gelöscht werden.
import Grundgeruest from "../layouts/Grundgeruest.astro";

// ---- Farben (exakt aus global.css) -------------------------------------------
const farben = [
  { name: "Papier",     var: "--papier",     wert: "#FCFBF9",              rolle: "Warmes Weiß · Hauptfläche / Body", dunkel: false },
  { name: "Sand",       var: "--sand",       wert: "#D9D7D1",              rolle: "Greige · Bänder (Hero, Fuß, Seitenköpfe, Kontakt)", dunkel: false },
  { name: "Sand-Linie", var: "--sand-linie", wert: "#C7C4BB",              rolle: "Karolinien-Textur · Prozess-Nummern (Ruhe)", dunkel: false },
  { name: "Tinte",      var: "--tinte",      wert: "#1A1712",              rolle: "Warmes Schwarz · Text & dunkle Flächen", dunkel: true },
  { name: "Ton",        var: "--ton",        wert: "#8A857B",              rolle: "Gedämpftes Grau · Meta, Nebeninfos, Kundennamen", dunkel: true },
  { name: "Haar",       var: "--haar",       wert: "rgba(26,23,18,0.16)",  rolle: "Haarlinien / Trenner / Umrisse (16 % Tinte)", dunkel: false },
  { name: "Display-Schwarz", var: "—",       wert: "#1b1b1b",              rolle: "Fast-Schwarz · Display-Schrift (Masthead, Titel, Signatur) — minimal heller als Tinte", dunkel: true },
  { name: "Reinweiß",   var: "—",            wert: "#FFFFFF",              rolle: "Kontakt-Riesentitel & Hover-Highlights", dunkel: false },
];

// ---- Schriftfamilien ---------------------------------------------------------

  // — Display / Signature —
  { gruppe: "Display & Signature", k: "masthead", name: "Masthead-Wort „PORTFOLIO“", wo: "Startseite-Hero (real als WebP-Grafik; hier Typo-Spezifikation + Serif-Hover)",
    famVar: "var(--grotesk)", fam: "Archivo", weight: 900, style: "normal", size: "clamp(2.6rem, 16.5vw, 14rem)", tracking: "-0.02em", transform: "uppercase", color: "#1b1b1b", bg: "var(--sand)", probe: "PORTFOLIO" },

// Farb-Anwendungsmatrix („Schriften jeweils in den Farben“)
const kombis = [
  { text: "var(--tinte)",  bg: "var(--papier)", tl: "Tinte",   bl: "auf Papier",   note: "Standard-Text" },
  { text: "var(--ton)",    bg: "var(--papier)", tl: "Ton",     bl: "auf Papier",   note: "Meta / Nebeninfo" },
  { text: "#1b1b1b",       bg: "var(--papier)", tl: "Display", bl: "auf Papier",   note: "Titel / Masthead" },
  { text: "var(--tinte)",  bg: "var(--sand)",   tl: "Tinte",   bl: "auf Sand",     note: "Text auf Bändern" },
  { text: "var(--ton)",    bg: "var(--sand)",   tl: "Ton",     bl: "auf Sand",     note: "Meta auf Bändern" },
  { text: "#FFFFFF",       bg: "var(--sand)",   tl: "Reinweiß",bl: "auf Sand",     note: "Kontakt-Riese" },
  { text: "var(--papier)", bg: "var(--tinte)",  tl: "Papier",  bl: "auf Tinte",    note: "Buttons / WIP (invertiert)" },
  { text: "#FFFFFF",       bg: "var(--tinte)",  tl: "Reinweiß",bl: "auf Tinte",    note: "Hover-Highlight" },
];

const gruppen = [...new Set(rollen.map((r) => r.gruppe))];
---

<Grundgeruest titel="Styleguide — Annasthasia Reichert" beschreibung="Interne Design-Übersicht: Schriften, Schnitte, Größen und Farben.">
  <!-- Viewport-Badge: zeigt live, ob gerade Desktop oder Mobil gemessen wird -->
  <div class="sg-badge" id="sg-badge" aria-live="polite"></div>

  <main class="sg">
    <div class="sg-head">
      <p class="sg-kicker">Design-Übersicht</p>
      <h1 class="sg-h1">Schriften, Schnitte, Größen &amp; Farben</h1>
      <p class="sg-intro">
        Alle verwendeten Schriften an allen Orten der Website — gerendert mit den echten
        Projekt-Schriften und Farb-Tokens. Die Größen sind <strong>responsiv</strong> (per
        <code>clamp()</code>): jede Probe zeigt ihre aktuell gemessene Größe. Schmale das Fenster
        auf Handybreite (≤ 760 px), um die Mobil-Werte zu sehen — das Badge oben rechts sagt dir,
        in welchem Modus du gerade bist.
      </p>
    </div>

    <!-- ===================== FARBEN ===================== -->
    <section class="sg-section">
      <h2 class="sg-h2">1 · Farbpalette</h2>
      <p class="sg-lead">Neutral, kein bunter Akzent — Farbe kommt ausschließlich über die Projektinhalte.</p>
      <div class="sg-farbgitter">
        {farben.map((f) => (
          <div class="sg-farbkarte">
            <div class="sg-farbfeld" style={`background:${f.wert}`}>
              <span class={"sg-farbhex " + (f.dunkel ? "hell" : "dunkel")}>{f.wert}</span>
            </div>
            <div class="sg-farbtext">
              <strong>{f.name}</strong>
              <code>{f.var}</code>
              <span>{f.rolle}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ===================== SCHRIFTEN ===================== -->
    <section class="sg-section">
      <h2 class="sg-h2">2 · Schriftfamilien</h2>
      <p class="sg-lead">Drei Familien, klar getrennte Rollen.</p>
      <div class="sg-fam-liste">
        {familien.map((fa) => (
          <div class="sg-fam">
            <div class="sg-fam-probe" style={`font-family:${fa.fam}; font-style:${fa.italic ? "italic" : "normal"}`}>
              {fa.probe}
            </div>
            <div class="sg-fam-meta">
              <strong>{fa.name}</strong>
              <span class="sg-tag">{fa.token}</span>
              <p>{fa.rolle}</p>
              <p class="sg-fein">{fa.geladen}</p>
            </div>
          </div>
        ))}
      </div>

      <h3 class="sg-h3">Archivo — Gewichtsleiter (geladen)</h3>
      <div class="sg-gewichte">
        {gewichte.map((g) => (
          <div class="sg-gewicht">
            <span class="sg-gewicht-probe" style={`font-family:var(--grotesk); font-weight:${g.w}`}>Aa</span>
            <span class="sg-gewicht-label">{g.w} · {g.n}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ===================== TYPO-ROLLEN ===================== -->
    <section class="sg-section">
      <h2 class="sg-h2">3 · Typo-Rollen — jede Stelle der Seite</h2>
      <p class="sg-lead">
        Jede Karte zeigt die echte Schrift in ihrer echten Farbe auf ihrem echten Untergrund.
        <strong>Größe</strong> = live gemessen (aktueller Viewport) · dahinter der responsive
        <code>clamp()</code>-Bereich.
      </p>

      {gruppen.map((g) => (
        <div class="sg-gruppe">
          <h3 class="sg-h3">{g}</h3>
          <div class="sg-karten">
            {rollen.filter((r) => r.gruppe === g).map((r) => (
              <article class="sg-karte">
                <div class="sg-probe-flaeche" style={`background:${r.bg}`}>
                  <span
                    class="sg-probe"
                    data-k={r.k}
                    style={`font-family:${r.famVar}; font-weight:${r.weight}; font-style:${r.style};
                            font-size:${r.size}; letter-spacing:${r.tracking};
                            text-transform:${r.transform}; color:${r.color};
                            ${r.opacity ? `opacity:${r.opacity};` : ""}
                            ${r.border ? "border:1px solid " + r.color + "; border-radius:999px; padding:0.5rem 1.1rem;" : ""}
                            ${!r.border && (r.k === "knopf" || r.k === "filter") ? "border-radius:999px; padding:0.55rem 1.2rem;" : ""}`}
                  >{r.probe}</span>
                </div>
                <div class="sg-karte-meta">
                  <strong class="sg-karte-name">{r.name}</strong>
                  <p class="sg-wo">{r.wo}</p>
                  <dl class="sg-specs">
                    <div><dt>Familie</dt><dd>{r.fam}</dd></div>
                    <div><dt>Gewicht</dt><dd>{r.weight}{r.style === "italic" ? " · kursiv" : ""}</dd></div>
                    <div><dt>Tracking</dt><dd>{r.tracking}</dd></div>
                    <div><dt>Transform</dt><dd>{r.transform === "none" ? "—" : r.transform}</dd></div>
                    <div class="sg-spec-farbe"><dt>Farbe</dt><dd><span class="sg-farbpunkt" style={`background:${r.color}`}></span>{r.color.replace("var(","").replace(")","")}</dd></div>
                    <div class="sg-spec-groesse"><dt>Größe</dt><dd><b class="sg-live" data-live={r.k}>–</b> <span class="sg-clamp">{r.size}</span></dd></div>
                  </dl>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- ===================== FARB-ANWENDUNG ===================== -->
    <section class="sg-section">
      <h2 class="sg-h2">4 · Schrift in Farbe — Kombinationen</h2>
      <p class="sg-lead">Welche Text- auf welcher Hintergrundfarbe tatsächlich vorkommt.</p>
      <div class="sg-kombis">
        {kombis.map((c) => (
          <div class="sg-kombi" style={`background:${c.bg}`}>
            <span class="sg-kombi-text" style={`color:${c.text}`}>Annasthasia Reichert</span>
            <span class="sg-kombi-label" style={`color:${c.text}`}>{c.tl} {c.bl}</span>
            <span class="sg-kombi-note" style={`color:${c.text}; opacity:0.7`}>{c.note}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="sg-fuss">
      <p>Interne Referenz · nicht in der Navigation verlinkt · Quelle: <code>src/styles/global.css</code></p>
    </div>
  </main>
</Grundgeruest>


    token: "--grotesk", geladen: "Selbst gehostet · Gewichte 400 · 500 · 600 · 700 · 800 · 900",
    gewichte: "400–900",
    rolle: "Arbeitspferd: Nachname, Überschriften, Titel, Fließtext, Labels, Buttons.",
    probe: "reichert.",

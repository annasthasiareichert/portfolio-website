// Archivo-Gewichtsleiter
const gewichte = [
  { w: 400, n: "Regular" }, { w: 500, n: "Medium" }, { w: 600, n: "SemiBold" },
  { w: 700, n: "Bold" }, { w: 800, n: "ExtraBold" }, { w: 900, n: "Black" },

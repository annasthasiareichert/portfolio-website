---
// Kontakt — eigene, ungestörte Kontaktseite (siehe docs/domain-model.md D11):
// kein Formular, klickbare E-Mail + Telefon + Adresse, plus LinkedIn.
import Grundgeruest from "../layouts/Grundgeruest.astro";
import Kopf from "../components/Kopf.astro";
import Fuss from "../components/Fuss.astro";
---

<Grundgeruest
  titel="Kontakt — Annasthasia Reichert"
  beschreibung="Kontaktmöglichkeiten von Annasthasia Reichert — Grafik- & UI-Designerin aus Köln."
>
  <Kopf />

  <main class="unterseite kontakt-seite">
    <section class="kontakt-buehne">
      <h1 class="visually-hidden">Kontakt — Annasthasia Reichert</h1>

      <!-- Titel: kleines weißes „Kontakt“ über dem Namens-Lockup -->
      <div class="kontakt-titel" aria-hidden="true">
        <span class="kontakt-riese">Kontakt</span>
        <span class="kontakt-name">annasthasia reichert</span>
      </div>

      <!-- Porträt, bündig in der rechten unteren Ecke -->
      <img class="kontakt-portraet" src="/portraet-kontakt.png" alt="Porträt von Annasthasia Reichert" width="884" height="1180" />

      <!-- Kontaktdaten unten links -->
      <address class="kontakt-daten-block">
        <p class="kontakt-adresse"><span class="ort-strasse">Lenbachstraße 9</span><span class="ort-stadt">50733 Köln</span></p>
        <p><a href="tel:+491725401188">+49 172 5401188</a></p>
        <p class="kontakt-mail"><a href="mailto:annasthasiareichert@gmx.de">annasthasiareichert@gmx.de</a></p>
      </address>
    </section>
  </main>

  <Fuss schlicht />

  <script>
    import "../scripts/interaktionen.js";
  </script>
</Grundgeruest>

---
// Über mich — eigene Unterseite. Scroll-Szene: Eine 3D-Cartoon-Figur von
// Annasthasia dreht sich beim Scrollen Frame für Frame (Video aus Einzelbildern)
// und schraubt sich dabei langsam die Seite hinunter. Im Wechsel poppen links &
// rechts kleine Steckbrief-Hinweise auf. Umsetzung: /scripts/ueber-mich.js.
// Ohne JS oder bei reduzierter Bewegung bleibt der statische Steckbrief stehen.
import Grundgeruest from "../layouts/Grundgeruest.astro";
import Kopf from "../components/Kopf.astro";
import Fuss from "../components/Fuss.astro";

// Reihenfolge der Hinweise, so wie die Figur nach unten wandert. `at` =
// Scroll-Fortschritt (0–1), bei dem der Hinweis aufpoppt. Ober-/unterhalb der
// Figur platziert ueber-mich.js automatisch (immer die freie Seite), damit die
// Fakten die Cartoon-Figur nie überdecken. Ohne Kicker-Überschrift — schlanker.
const hinweise = [
  { at: 0.06,
    de: 'Meine Freunde nennen mich <em>Stacy</em>.',
    en: 'My friends call me <em>Stacy</em>.' },
  { at: 0.20,
    de: 'Für nahezu <em>jedes kreative Hobby</em> zu begeistern.',
    en: 'Up for <em>almost any creative hobby</em>.' },
  { at: 0.35,
    de: 'Aufgewachsen in <em>Dortmund</em>.',
    en: 'Grew up in <em>Dortmund</em>.' },
  { at: 0.50,
    de: '<em>Interior Design</em> ist eine meiner großen Leidenschaften.',
    en: '<em>Interior design</em> is one of my great passions.' },
  { at: 0.65,
    de: 'Seit <em>6&nbsp;Jahren</em> in <em>Köln</em> zuhause.',
    en: 'Home in <em>Cologne</em> for <em>6&nbsp;years</em>.' },
  { at: 0.80,
    de: 'Ich <em>male und bastle</em>, seit ich denken kann.',
    en: "I've <em>painted and crafted</em> for as long as I can remember." },
];
---

<Grundgeruest
  titel="Über mich — Annasthasia Reichert"
  beschreibung="Über Annasthasia Reichert — Grafik- & UI-Designerin aus Köln."
>
  <Kopf />

  <main class="unterseite">
    <section class="seitenkopf auftritt">
      <h1 class="seitentitel">Über mich</h1>
      <p
        class="seitenkopf-unter"
        data-de='Ein kleiner Steckbrief — <span class="vn">annasthasia</span>, für Freunde Stacy.'
        data-en='A little profile — <span class="vn">annasthasia</span>, Stacy to my friends.'
        set:html='Ein kleiner Steckbrief — <span class="vn">annasthasia</span>, für Freunde Stacy.'
      ></p>
    </section>

    <!-- Scroll-Szene: von ueber-mich.js aktiviert (nur bei erlaubter Bewegung + JS) -->
    <section class="szene" id="szene" hidden>
      <div class="szene-sticky">
        <p class="scroll-hinweis" data-de="Scrollen" data-en="Scroll">Scrollen</p>

        <div class="szene-buehne">
          <div class="figur-wrap">
            <canvas class="figur-canvas" aria-label="Annasthasia als animierte 3D-Cartoon-Figur"></canvas>
          </div>

          <ul class="hinweise">
            {hinweise.map((h) => (
              <li class="hinweis" data-at={h.at}>
                <p class="sb-text" data-de={h.de} data-en={h.en} set:html={h.de}></p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>

  <Fuss />

  <script>
    import "../scripts/interaktionen.js";
    import { starteUeberMich } from "../scripts/ueber-mich.js";
    starteUeberMich();
  </script>
</Grundgeruest>

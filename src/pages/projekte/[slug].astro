---
// Projekt-Detailseite — eine eigene Unterseite je Projekt (/projekte/<slug>).
// Astro erzeugt aus src/data/projekte.ts automatisch für jedes Projekt eine Seite.
// Ist `fall` gesetzt, wird eine reiche Fallstudie aus Blöcken gerendert (Fallblock.astro),
// sonst greift die einfache Galerie (Intro + Vorschaubild).
import Grundgeruest from "../../layouts/Grundgeruest.astro";
import Kopf from "../../components/Kopf.astro";
import Fuss from "../../components/Fuss.astro";
import Fallblock from "../../components/Fallblock.astro";
import { projekte } from "../../data/projekte";

export function getStaticPaths() {
  return projekte.map((p, i) => ({
    params: { slug: p.slug },
    props: {
      projekt: p,
      index: i,
      naechstes: projekte[(i + 1) % projekte.length],
    },
  }));
}

const { projekt, index, naechstes } = Astro.props;
// Jahr aus dem meta-Feld ("Kategorie · Jahr") — je Sprache getrennt, da z. B.
// "laufend" / "ongoing" abweichen. Wird neben dem Unternehmensnamen gezeigt.
const jahrDe = projekt.meta.de.split("·").pop()?.trim() ?? "";
const jahrEn = projekt.meta.en.split("·").pop()?.trim() ?? "";
const hatFall = !!(projekt.fall && projekt.fall.length);
// Bringt die Fallstudie schon eigene Bilder mit? Wenn nicht (rein textliche Aufbereitung),
// zeigen wir das Karten-Vorschaubild klein und randbündig als Platzhalter.
const fallHatBild = !!projekt.fall?.some((b) => b.art === "bild" || b.art === "paar");
const zeigeVorschau = hatFall && !fallHatBild;
// Randseite je Projekt abwechselnd (rechts/links) für etwas Rhythmus.
const vorschauSeite = index % 2 === 0 ? "rechts" : "links";
// Galerie (einfache Variante): zusätzliche Bilder, sonst nur das Vorschaubild
const galerie = projekt.bilder && projekt.bilder.length ? projekt.bilder : [projekt.bild];
---

<Grundgeruest
  titel={`${projekt.titel.de} — ${projekt.kunde.de} · Annasthasia Reichert`}
  beschreibung={projekt.beschreibung ? projekt.beschreibung.de : `${projekt.titel.de} für ${projekt.kunde.de}.`}
>
  <Kopf />

  <!-- Ankunft des Karten-Flugs von der Startseite: läuft synchron noch VOR dem
       ersten Malen. Baut die Papier-Deckschicht (html.karten-ankunft) und die
       fliegende Karte an exakt dem Rechteck auf, an dem sie auf der Startseite
       stehen geblieben ist — so gibt es keinen sichtbaren Bruch. Den Weiterflug
       ins erste Projektbild übernimmt scripts/ankunft.js (unten). -->
  <script define:vars={{ slug: projekt.slug }}>
    (() => {
      try {
        const roh = sessionStorage.getItem("kartenflug");
        if (!roh) return;
        const flug = JSON.parse(roh);
        // Frische-Fenster großzügig (15 s): auch ein langsamer Seitenaufbau darf den
        // Flug noch annehmen. Veraltete Reste räumen faecher.js/ankunft.js ohnehin weg.
        const frisch = flug && flug.slug === slug && flug.rect && Date.now() - flug.t < 15000;
        const ruhig = matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (!frisch || ruhig) { sessionStorage.removeItem("kartenflug"); return; }
        document.documentElement.classList.add("karten-ankunft", "karten-ankunft-still");
        const el = document.createElement("div");
        el.className = "ankunft-karte";
        el.style.cssText =
          `left:${flug.rect.left}px;top:${flug.rect.top}px;` +
          `width:${flug.rect.width}px;height:${flug.rect.height}px;` +
          `background-image:url('${flug.bild}')`;
        document.body.appendChild(el);
      } catch (_) {}
    })();
  </script>

  <main class="unterseite projektseite">
    <!-- Sand-Kopfband mit Titel, Kunde und Leistungen -->
    <section class="seitenkopf projekt-kopf">
      <a class="projekt-zurueck mono" href="/projekte" data-de="← zurück zu den Projekten" data-en="← back to projects">← zurück zu den Projekten</a>
      <h1 class="seitentitel" data-de={projekt.titel.de} data-en={projekt.titel.en}>{projekt.titel.de}</h1>
      <p class="seitenkopf-unter projekt-kopf-unter">
        <span class="kursiv" data-de={projekt.kunde.de} data-en={projekt.kunde.en}>{projekt.kunde.de}</span>
        {jahrDe && <span class="projekt-jahr mono" data-de={jahrDe} data-en={jahrEn}>{jahrDe}</span>}
      </p>
      {projekt.leistungen && (
        <ul class="pill-liste projekt-leistungen">
          {projekt.leistungen.map((l) => <li class="pill">{l}</li>)}
        </ul>
      )}
    </section>

    {hatFall ? (
      <div class="fall-inhalt">
        {zeigeVorschau && (
          <figure class={`projekt-vorschau projekt-vorschau-${vorschauSeite} auftritt`}>
            <img src={projekt.bild} alt={`${projekt.titel.de} – ${projekt.kunde.de}`} loading="eager" decoding="async" />
            <figcaption class="mono" data-de="Platzhalter – finale Bilder folgen." data-en="Placeholder – final visuals coming soon.">Platzhalter – finale Bilder folgen.</figcaption>
          </figure>
        )}
        {projekt.fall!.map((block, i) => <Fallblock block={block} eager={i === 0} />)}

        <!-- Weiter blättern -->
        <nav class="projekt-nav">
          <a class="pfeil-link projekt-zurueck-fuss" href="/projekte" data-de="← alle Projekte" data-en="← all projects">← alle Projekte</a>
          <a class="naechstes-projekt" href={`/projekte/${naechstes.slug}`}
             data-de={`nächstes Projekt: ${naechstes.titel.de} →`}
             data-en={`next project: ${naechstes.titel.en} →`}>nächstes Projekt: {naechstes.titel.de} →</a>
        </nav>
      </div>
    ) : (
      <div class="projekt-inhalt">
        {projekt.beschreibung && (
          <p class="projekt-intro" data-de={projekt.beschreibung.de} data-en={projekt.beschreibung.en}>{projekt.beschreibung.de}</p>
        )}

        <div class="projekt-galerie">
          {galerie.map((b, i) => (
            <figure class="projekt-figur">
              <img src={b} alt={`${projekt.titel.de} – ${projekt.kunde.de}`} loading={i === 0 ? "eager" : "lazy"} decoding="async" />
            </figure>
          ))}
        </div>

        <p class="projekt-platzhalter mono" data-de="Weitere Bilder & Details folgen." data-en="More visuals & details coming soon.">Weitere Bilder & Details folgen.</p>

        <!-- Weiter blättern -->
        <nav class="projekt-nav">
          <a class="pfeil-link projekt-zurueck-fuss" href="/projekte" data-de="← alle Projekte" data-en="← all projects">← alle Projekte</a>
          <a class="naechstes-projekt" href={`/projekte/${naechstes.slug}`}
             data-de={`nächstes Projekt: ${naechstes.titel.de} →`}
             data-en={`next project: ${naechstes.titel.en} →`}>nächstes Projekt: {naechstes.titel.de} →</a>
        </nav>
      </div>
    )}
  </main>

  <Fuss />

  <script>
    import "../../scripts/interaktionen.js";
    import "../../scripts/ankunft.js";
  </script>
</Grundgeruest>

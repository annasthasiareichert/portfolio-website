---
// Kopfzeile mit AR-Logo (schwarzes Favicon), Navigation und DE/EN-Umschalter.
// Auf dem Handy klappt alles hinter einem Hamburger-Menü oben rechts zusammen.
// data-ghost = fette Breitenreserve (siehe global.css), aria-current markiert
// den aktuellen Menüpunkt (wird dann fett dargestellt).
const pfad = Astro.url.pathname;
---

<header>
  <a href="/" class="wortmarke" aria-label="Annasthasia Reichert – zur Startseite">
    <img class="wortmarke-logo" src="/logo-ar.png" alt="" width="44" height="44" />
  </a>

  <!-- Hamburger: öffnet auf dem Handy das Menü. Auf dem Desktop ausgeblendet.
       Die drei Striche werden im offenen Zustand zu einem X (siehe global.css). -->
  <button
    id="menue-knopf"
    class="menue-knopf"
    type="button"
    aria-label="Menü öffnen"
    aria-expanded="false"
    aria-controls="hauptmenue"
  >
    <span class="menue-strich"></span>
    <span class="menue-strich"></span>
    <span class="menue-strich"></span>
  </button>

  <nav id="hauptmenue">
    <div class="nav-links">
      <a href="/" data-de="Home" data-en="Home" data-ghost="Home" aria-current={pfad === "/" ? "page" : undefined}>Home</a>
      <a href="/projekte" class="nav-arbeiten" data-de="Projekte" data-en="Projects" data-ghost="Projekte" aria-current={pfad.startsWith("/projekte") ? "page" : undefined}>Projekte</a>
      <a href="/ueber-mich" data-de="Über mich" data-en="About" data-ghost="Über mich" aria-current={pfad === "/ueber-mich" ? "page" : undefined}>Über mich</a>
      <a href="/lebenslauf" data-de="Lebenslauf" data-en="Resume" data-ghost="Lebenslauf" aria-current={pfad === "/lebenslauf" ? "page" : undefined}>Lebenslauf</a>
      <a href="/kontakt" data-de="Kontakt" data-en="Contact" data-ghost="Kontakt" aria-current={pfad === "/kontakt" ? "page" : undefined}>Kontakt</a>
    </div>
    <a
      class="kopf-linkedin"
      href="https://www.linkedin.com/in/annasthasia-leandra-reichert/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn-Profil von Annasthasia Reichert (öffnet in neuem Tab)"
    >
      <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M4.98 3.5A2.49 2.49 0 1 1 5 8.48a2.49 2.49 0 0 1-.02-4.98zM3 9.75h4v11.5H3zM9.5 9.75h3.83v1.57h.05c.53-1.01 1.84-2.07 3.79-2.07 4.05 0 4.8 2.67 4.8 6.14v5.86h-4v-5.2c0-1.24-.02-2.83-1.72-2.83-1.73 0-1.99 1.35-1.99 2.74v5.29h-3.76z"/>
      </svg>
      <span class="kopf-linkedin-text">LinkedIn</span>
    </a>
    <div class="sprache" role="group" aria-label="Sprache wählen">
      <button data-lang="de" class="aktiv">DE</button>
      <button data-lang="en">EN</button>
    </div>
  </nav>
</header>

---
// Hero / Masthead: Das Porträt verschmilzt mit dem Riesenwort „portfolio".
// Beim Hover wandelt sich die Schrift von fetter Grotesk zu kursiver Serife
// und ein Namens-Label folgt dem Cursor (siehe interaktionen.js).
---

<section class="hero" id="hero">
  <p class="eyebrow mono" data-de="Grafik- &amp; UI-Design · Köln" data-en="Graphic &amp; UI Design · Cologne">Grafik- &amp; UI-Design · Köln</p>

  <div class="masthead" aria-label="Annasthasia Reichert — Portfolio">
    <h1 class="visually-hidden">Annasthasia Reichert — Portfolio</h1>
    <span class="mh-wort grotesk solid" aria-hidden="true">portfolio</span>
    <span class="mh-wort serif solid" aria-hidden="true">portfolio</span>
    <img class="mh-figur" src="/portrait-frei.png" alt="Porträt von Annasthasia Reichert" />
    <span class="mh-wort grotesk line" aria-hidden="true">portfolio</span>
    <span class="mh-wort serif line" aria-hidden="true">portfolio</span>
  </div>

  <p class="mh-signatur"><span class="vn">annasthasia</span> reichert.</p>

  <div class="scroll-hinweis mono">
    <span class="strich"></span>
    <span data-de="Scrollen" data-en="Scroll">Scrollen</span>
  </div>
</section>

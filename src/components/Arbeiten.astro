---
// „ausgewählte arbeiten" — schwebender 3D-Karten-Fächer.
// Die Projekte aus src/data/projekte.ts liegen als Karten zentriert und leicht
// gefächert auf der Bühne. Beim Hover hebt sich eine Karte heraus, im Hintergrund
// erscheint groß ihr Titel (Archivo Black), darunter mittig der Kundenname.
// Klick → Detailseite, mit einem „Hineinschweben"-Übergang (siehe scripts/faecher.js).
// Auf dem Handy wird derselbe Kartenstapel zu einem wischbaren Karussell.
import { projekte } from "../data/projekte";
const anzahl = projekte.length;
---

<section class="arbeiten" id="arbeiten">
  <div class="kopf auftritt">
    <h2>
      <a href="/projekte" data-de="Ausgewählte Arbeiten" data-en="Selected Work">Ausgewählte Arbeiten</a>
    </h2>
  </div>

  <div class="faecher auftritt" id="faecher">
    <!-- Großes Titel-Wort hinter den Karten (dekorativ, per JS beim Hover gesetzt) -->
    <p class="faecher-wort" id="faecher-wort" aria-hidden="true"></p>

    <ul class="faecher-karten" id="faecher-karten" style={`--n:${anzahl}`}>
      {projekte.map((p, i) => (
        <li class="fk" style={`--i:${i}`}>
          <a
            class="fk-a"
            href={`/projekte/${p.slug}`}
            data-slug={p.slug}
            data-bild={p.bild}
            data-titel-de={p.titel.de}
            data-titel-en={p.titel.en}
            data-kunde-de={p.kunde.de}
            data-kunde-en={p.kunde.en}>
            <span class="fk-schwebe">
              <span class="fk-karte">
                <span class="fk-bild" style={`background-image:url('${p.bild}')`} aria-hidden="true"></span>
                <span class="fk-schein" aria-hidden="true"></span>
              </span>
            </span>
            <span class="fk-label">
              <span class="fk-titel" data-de={p.titel.de} data-en={p.titel.en}>{p.titel.de}</span>
              <span class="fk-kunde" data-de={p.kunde.de} data-en={p.kunde.en}>{p.kunde.de}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <!-- Kundenname mittig unter dem Fächer (Desktop; per JS beim Hover gesetzt) -->
    <p class="faecher-kunde" id="faecher-kunde" aria-hidden="true"></p>

    <p class="faecher-hinweis mono" aria-hidden="true"
       data-de="über eine Karte fahren · klicken zum Öffnen"
       data-en="hover a card · click to open">über eine Karte fahren · klicken zum Öffnen</p>
  </div>
</section>

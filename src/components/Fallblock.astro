---
// Ein Abschnitt einer Projekt-Fallstudie. Rendert je nach `art`:
//  · "bild"    – ein Bild auf einer Bühne (papier/sand/dunkel), optional mit Label & Beschriftung
//  · "paar"    – zwei Bilder nebeneinander auf einer Bühne (z. B. Mobile + App-Icon)
//  · "text"    – Textabschnitt; erste Zeile als große Serifen-Kursiv-Aussage, wenn `lead`
//  · "prozess" – nummerierte Schritte (Titel + Text)
//  · "liste"   – unnummerierte Aufzählung (Label + Punkte)
// Alle sichtbaren Texte tragen data-de/data-en für die Sprachumschaltung (interaktionen.js).
import type { FallBlock } from "../data/projekte";
// `eager` = erstes Bild der Seite sofort laden (Hero), damit beim ersten Blick sichtbar.
const { block, eager = false } = Astro.props as { block: FallBlock; eager?: boolean };
const ladeArt = eager ? "eager" : "lazy";
---

{block.art === "bild" && (
  <section class="fall-abschnitt auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    <figure class="fall-figur">
      <div class="fall-buehne" data-buehne={block.buehne ?? "papier"}>
        <img
          src={block.bild}
          alt={block.alt.de}
          loading={ladeArt}
          decoding="async"
          style={block.max ? `--bild-max:${block.max}` : undefined}
        />
      </div>
      {block.unterschrift && (
        <figcaption class="fall-unterschrift" data-de={block.unterschrift.de} data-en={block.unterschrift.en}>{block.unterschrift.de}</figcaption>
      )}
    </figure>
  </section>
)}

{block.art === "paar" && (
  <section class="fall-abschnitt auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    <figure class="fall-figur">
      <div class="fall-buehne fall-paar" data-buehne={block.buehne ?? "sand"}>
        <div class="paar-inhalt">
          {block.bilder.map((b) => (
            <span class="paar-figur" style={b.max ? `--bild-max:${b.max}` : undefined}>
              <img src={b.bild} alt={b.alt.de} loading={ladeArt} decoding="async" />
              {b.unterschrift && (
                <span class="paar-cap" data-de={b.unterschrift.de} data-en={b.unterschrift.en}>{b.unterschrift.de}</span>
              )}
            </span>
          ))}
        </div>
      </div>
    </figure>
  </section>
)}

{block.art === "text" && (
  <section class="fall-abschnitt fall-text auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    {block.absaetze.map((a, i) => (
      <p class={block.lead && i === 0 ? "fall-lead" : "fall-absatz"} data-de={a.de} data-en={a.en}>{a.de}</p>
    ))}
  </section>
)}

{block.art === "prozess" && (
  <section class="fall-abschnitt auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    <ol class="fall-prozess-liste">
      {block.schritte.map((s, i) => (
        <li class="fall-schritt">
          <span class="fall-schritt-nr" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
          <div class="fall-schritt-text-block">
            <h3 class="fall-schritt-titel" data-de={s.titel.de} data-en={s.titel.en}>{s.titel.de}</h3>
            <p class="fall-schritt-text" data-de={s.text.de} data-en={s.text.en}>{s.text.de}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
)}

{block.art === "liste" && (
  <section class="fall-abschnitt fall-text auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    <ul class="fall-liste">
      {block.punkte.map((p) => (
        <li class="fall-liste-punkt" data-de={p.de} data-en={p.en}>{p.de}</li>
      ))}
    </ul>
  </section>
)}

{block.art === "galerie" && (
  <section class="fall-abschnitt auftritt">
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    <div class="fall-galerie" data-buehne={block.buehne ?? "papier"}>
      {block.bilder.map((b) => (
        <figure class="galerie-figur" style={b.max ? `--bild-max:${b.max}` : undefined}>
          <img src={b.bild} alt={b.alt.de} loading={ladeArt} decoding="async" />
          {b.unterschrift && (
            <figcaption class="galerie-cap" data-de={b.unterschrift.de} data-en={b.unterschrift.en}>{b.unterschrift.de}</figcaption>
          )}
        </figure>
      ))}
    </div>
  </section>
)}

{block.art === "auslage" && (
  <section class="fall-abschnitt auslage auftritt" data-auslage>
    {block.label && (
      <p class="fall-label" data-de={block.label.de} data-en={block.label.en}>{block.label.de}</p>
    )}
    {block.einleitung && (
      <p class="auslage-einleitung kursiv" data-de={block.einleitung.de} data-en={block.einleitung.en}>{block.einleitung.de}</p>
    )}
    <div class="auslage-raster">
      {/* Fester Bildplatz: alle Bilder liegen gestapelt, nur das aktive ist sichtbar */}
      <figure class="auslage-figur">
        <div class="fall-buehne auslage-buehne" data-buehne={block.buehne ?? "sand"}>
          {block.stuecke.map((s, i) => (
            <img
              class={`auslage-bild${i === 0 ? " aktiv" : ""}`}
              data-bild={i}
              src={s.bild}
              alt={s.alt.de}
              data-alt-de={s.alt.de}
              data-alt-en={s.alt.en}
              loading={ladeArt}
              decoding="async"
            />
          ))}
        </div>
        <figcaption
          class="fall-unterschrift auslage-cap"
          data-de={block.stuecke[0].unterschrift?.de ?? block.stuecke[0].wort.de}
          data-en={block.stuecke[0].unterschrift?.en ?? block.stuecke[0].wort.en}
        >{block.stuecke[0].unterschrift?.de ?? block.stuecke[0].wort.de}</figcaption>
      </figure>

      {/* Wortliste (Menü): Hover/Tippen wechselt Bild + Unterschrift */}
      <ul class="auslage-worte" role="list">
        {block.stuecke.map((s, i) => (
          <li>
            <button
              type="button"
              class={`auslage-wort${i === 0 ? " aktiv" : ""}`}
              data-ziel={i}
              data-cap-de={s.unterschrift?.de ?? s.wort.de}
              data-cap-en={s.unterschrift?.en ?? s.wort.en}
            >
              <span class="auslage-wort-nr" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <span class="auslage-wort-text" data-de={s.wort.de} data-en={s.wort.en}>{s.wort.de}</span>
            </button>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
